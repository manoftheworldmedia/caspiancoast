            { "name": "ownerPhoto", "label": "About — owner photo", "type": "object", "fields": [{ "name": "src", "label": "Image", "type": "image" }, { "name": "alt", "label": "Alt text (EN)", "type": "string" }, { "name": "alt_fa", "label": "Alt text (فارسی)", "type": "string" }] },
            { "name": "rahiMom", "label": "About — Rahi & mom", "type": "object", "fields": [{ "name": "src", "label": "Image", "type": "image" }, { "name": "alt", "label": "Alt text (EN)", "type": "string" }, { "name": "alt_fa", "label": "Alt text (فارسی)", "type": "string" }] }
