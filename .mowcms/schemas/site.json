    {
      "name": "menu",
      "label": "Menu Page (hero + board images)",
      "icon": "menu",
      "kind": "single",
      "path": "menu.json",
      "fields": [
        {
          "name": "hero",
          "label": "Menu hero",
          "type": "object",
          "ui": { "group": "Hero" },
          "fields": [
            { "name": "eyebrow", "label": "Eyebrow (EN)", "type": "string" },
            { "name": "eyebrow_fa", "label": "Eyebrow (فارسی)", "type": "string" },
            { "name": "title", "label": "Title (EN)", "type": "string" },
            { "name": "title_fa", "label": "Title (فارسی)", "type": "string" },
            { "name": "sub", "label": "Sub-text (EN)", "type": "text" },
            { "name": "sub_fa", "label": "Sub-text (فارسی)", "type": "text" },
