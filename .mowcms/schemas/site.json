{
  "project": "caspiancoast",
  "label": "Caspian Coast Coffee",
  "description": "Persian café in Venice, California (Los Angeles). The portal edits the LIVE root data files the site actually serves — content.json (homepage + About + shared images/theme), menu.json (menu boards), shop.json (shop) — plus the home FAQ list in content/home.json and the News/Articles collection. Bilingual (English / فارسی) via adjacent _fa-suffixed fields. Edits go straight live; no manual sync.",
  "languages": [
    "en",
    "fa"
  ],
  "schemas": [
    {
      "name": "content",
      "label": "Homepage & About",
      "icon": "home",
      "kind": "single",
      "path": "content.json",
      "fields": [
        {
          "name": "hero",
          "label": "Hero",
          "type": "object",
          "ui": { "group": "Homepage — Hero" },
          "fields": [
            { "name": "eyebrow", "label": "Eyebrow (EN)", "type": "string" },
            { "name": "eyebrow_fa", "label": "Eyebrow (فارسی)", "type": "string" },
            { "name": "titleHtml", "label": "Headline (EN, allows <br>/<em>)", "type": "richtext" },
            { "name": "titleHtml_fa", "label": "Headline (فارسی, allows <br>/<em>)", "type": "richtext" },
            { "name": "subHtml", "label": "Sub-paragraph (EN, allows HTML)", "type": "richtext" },
            { "name": "subHtml_fa", "label": "Sub-paragraph (فارسی, allows HTML)", "type": "richtext" }
          ]
        },
        {
          "name": "intro",
          "label": "Intro",
          "type": "object",
          "ui": { "group": "Homepage — Intro" },
          "fields": [
            { "name": "q", "label": "Question (EN)", "type": "richtext" },
            { "name": "q_fa", "label": "Question (فارسی)", "type": "richtext" },
            { "name": "titleHtml", "label": "Title (EN, allows <br>/<em>)", "type": "richtext" },
            { "name": "titleHtml_fa", "label": "Title (فارسی, allows <br>/<em>)", "type": "richtext" },
            { "name": "body", "label": "Body (EN, allows HTML)", "type": "richtext" },
            { "name": "body_fa", "label": "Body (فارسی, allows HTML)", "type": "richtext" },
            { "name": "flavorsLabel", "label": "Flavors label (EN)", "type": "string" },
            { "name": "flavorsLabel_fa", "label": "Flavors label (فارسی)", "type": "string" },
            {
              "name": "image",
              "label": "Intro image",
              "type": "object",
              "fields": [
                { "name": "src", "label": "Image", "type": "image" },
                { "name": "alt", "label": "Alt text (EN)", "type": "string" },
                { "name": "alt_fa", "label": "Alt text (فارسی)", "type": "string" }
              ]
            }
          ]
        },
        {
          "name": "bakery",
          "label": "Bakery",
          "type": "object",
          "ui": { "group": "Homepage — Bakery" },
          "fields": [
            { "name": "eyebrow", "label": "Eyebrow (EN)", "type": "string" },
            { "name": "eyebrow_fa", "label": "Eyebrow (فارسی)", "type": "string" },
            { "name": "titleHtml", "label": "Title (EN, allows <br>/<em>)", "type": "richtext" },
            { "name": "titleHtml_fa", "label": "Title (فارسی, allows <br>/<em>)", "type": "richtext" },
